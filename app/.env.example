# Copy to .env and adjust values for the target GCP project.
# These are also the variables to pass to `gcloud run deploy --set-env-vars`.

# Required. The GCP project that hosts BigQuery, Vertex AI, and Cloud Run.
# If unset at runtime, the app falls back to the project from Application
# Default Credentials. On Cloud Run this comes from the metadata server.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# BigQuery dataset and table holding the indexed patent corpus.
BIGQUERY_DATASET=patent_research
BIGQUERY_TABLE=us_patents_indexed

# Vertex AI region. us-central1 is the default and where Gemini 2.5 is GA.
VERTEX_AI_LOCATION=us-central1

# Gemini model id. Use gemini-2.5-flash for cost; gemini-2.5-pro for quality.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Resource name of the BigQuery Data Transfer Scheduled Query that
# performs the patent data refresh. Required only if you want the in-app
# "Refresh data" button enabled. Format:
# projects/PROJECT/locations/REGION/transferConfigs/TRANSFER_CONFIG_ID
# REFRESH_TRANSFER_CONFIG=
